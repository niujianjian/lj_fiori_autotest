{
  "_version": "1.58.0",
  "sap.app": {
    "id": "demo.autotest",
    "type": "application",
    "title": "Auto Test Template",
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZUI5_AUTOTEST_SRV/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {},
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "demo.autotest.view.Main",
      "type": "XML",
      "id": "Main"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "defaultBindingMode": "TwoWay",
          "defaultCountMode": "Inline",
          "useBatch": false
        }
      }
    }
  }
}
