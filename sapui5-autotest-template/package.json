{
  "name": "sapui5-autotest-template",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal SAPUI5 app with QUnit, OPA5, and wdi5 test setup",
  "scripts": {
    "start": "ui5 serve -o index.html",
    "test:unit": "ui5 serve --port 8081 --open test/unit/unitTests.qunit.html",
    "test:opa": "ui5 serve --port 8081 --open test/integration/opaTests.qunit.html",
    "test:e2e": "wdio run wdio.conf.js --logLevel error",
    "deploy:a4h": "ui5 build preload --clean-dest --config ui5-deploy.yaml"
  },
  "config": {
    "chromedriver_filepath": "./chromedriver/chromedriver-win64.zip",
    "chromedriver_skip_download": "true"
  },
  "devDependencies": {
    "@sap-ux/ui5-middleware-fe-mockserver": "^2.4.10",
    "@ui5/cli": "^3.11.1",
    "@wdio/cli": "^8.43.0",
    "@wdio/local-runner": "^8.43.0",
    "@wdio/mocha-framework": "^8.43.0",
    "@wdio/spec-reporter": "^8.43.0",
    "chromedriver": "^146.0.6",
    "ui5-task-nwabap-deployer": "^2.1.1",
    "wdio-chromedriver-service": "^8.1.1",
    "wdio-ui5-service": "^2.2.1",
    "webdriverio": "^8.43.0"
  },
  "ui5": {
    "dependencies": [
      "ui5-task-nwabap-deployer"
    ]
  }
}
